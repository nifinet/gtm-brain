# Copy to .env and fill in.

# The reasoning layer. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: override the default model used by the judge + drafting layers.
GTM_BRAIN_MODEL=claude-sonnet-4-6

# Where the memory store lives. Defaults to ./gtm_brain.db
GTM_BRAIN_DB=gtm_brain.db
